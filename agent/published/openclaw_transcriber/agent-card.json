{
  "identity": {
    "agentName": "openclaw_transcriber",
    "displayName": "OpenClaw Transcriber",
    "description": "Transcribes a short voice clip (base64 audio) into text using the configured speech-to-text provider. Lets OpenClaw turn a microphone recording into a prompt.",
    "version": "1.0.0",
    "provider": {
      "organization": "openclaw-foundation"
    }
  },
  "capabilities": {
    "taskKinds": ["request"]
  },
  "io": {
    "inputs": [
      {
        "id": "request",
        "description": "Base64-encoded audio clip plus its container format (webm, wav, mp3, ogg, m4a, flac).",
        "contentType": "application/json",
        "required": true,
        "example": {
          "audio": "<base64-encoded audio bytes>",
          "format": "webm"
        },
        "schema": {
          "type": "object",
          "required": ["audio"],
          "properties": {
            "audio": {
              "type": "string"
            },
            "format": {
              "type": "string"
            }
          }
        }
      }
    ],
    "outputs": [
      {
        "id": "transcript",
        "description": "JSON { ok, text } with the transcribed text of the clip.",
        "contentType": "application/json",
        "guaranteed": true
      }
    ]
  },
  "tags": [
    {
      "id": "speech-to-text",
      "name": "Speech to Text",
      "description": "Transcribe a short audio clip into text."
    }
  ],
  "extensions": {
    "blocks": {
      "billingMode": "free",
      "pricePerTask": "0.000",
      "listing": "public"
    }
  },
  "runtime": {
    "handler": "./handler.ts",
    "handlerExport": "default",
    "concurrency": 1,
    "expectedInstances": 1,
    "maxRunningTimeSec": 90
  }
}
