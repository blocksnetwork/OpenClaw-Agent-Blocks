# OpenClaw foundation — environment (example).
#
# Copy to `.env` and fill in. `setup.sh token` will auto-generate the
# gateway token for you if you leave it blank.

# Required. Auto-generated by `./scripts/setup.sh token` if empty.
# Or generate manually with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# At least one LLM provider key is required for the gateway to answer
# skill calls.
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=

# Blocks.ai network. Needed once you start discovering/calling real
# agents from the Blocks catalog. Get a key from the Blocks dashboard,
# or run `blocks login --write-env` from inside the blocks-runner.
BLOCKS_API_KEY=

# --- foundation agent knobs ---
# Point the local agent at the gateway. Inside Docker this is the
# service hostname; from the host it is the published loopback port.
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# Run the end-to-end smoke without touching the network. When `1`, the
# agent uses the in-process mock Blocks catalog instead of the real SDK.
FOUNDATION_OFFLINE=1

# --- personal assistants (Part IV) ---
# Private per-owner assistant agents that can use the network and (later)
# talk to invited peers. Off by default; /api/assistant/* refuses when 0.
PERSONAL_ASSISTANTS_ENABLED=0
PA_MAX_ASSISTANTS=10               # live per-owner agents
PA_PER_CALL_USD_CAP=0.05           # per assistant invocation
PA_DAILY_USD_CAP=2.00              # rolling 24h across all assistants
PA_A2A_DAILY_CALLS_CAP=200         # stop a runaway assistant-to-assistant loop
PA_DEFAULT_LISTING=private         # per-owner agents are private by default
PA_DEFAULT_BILLING=free            # and free by default
# Opt into the live gateway-backed personal_assistant brain when the bridge
# is online. Default 0 keeps the deterministic offline brain; gateway errors
# or malformed plan envelopes fall back to that stub.
PA_BRAIN_LIVE=0

# --- write policy (Workstream D.3) ---
# PA_READONLY gates every write tool (calendar.createEvent, email.draft/send).
# Defaults ON (safe): reads work, writes are refused. For a hosted demo where
# the owner should be able to book/draft, set PA_READONLY=0 AND keep
# PA_BOOKING_POLICY=confirm so EVERY write is user-confirmed via the UI Confirm
# chip before it touches the real account (never silent auto-writes).
# PA_READONLY=1
# PA_BOOKING_POLICY=confirm        # confirm | auto  (recommend: confirm)

# Owner binding for a SERVED assistant's authorize() gate. The generated
# pa_<owner> handler bakes these in (assistant-factory.ts); pa_test_private
# reads them from env. Keyed on the Blocks ownerId/orgId (D6).
# PA_OWNER_ID=
# PA_OWNER_ORG_ID=

# --- calendar integration (Phase 8.1, read path) ---
# When set (and FOUNDATION_OFFLINE=0), the assistant's `calendar.freeBusy`
# action reads the owner's REAL calendar through an MCP server instead of
# the offline stub. Default points at @cocal/google-calendar-mcp; the
# spawned server reads the Google OAuth env below. Leave PA_CALENDAR_MCP_CMD
# empty to keep the deterministic offline stub.
# PA_CALENDAR_MCP_CMD=npx
# PA_CALENDAR_MCP_ARGS=-y @cocal/google-calendar-mcp
# PA_CALENDAR_WINDOW_DAYS=7
# Read by the spawned calendar MCP server (not the bridge itself):
# GOOGLE_OAUTH_CREDENTIALS=/home/node/.config/openclaw/gcp-oauth.keys.json
# GOOGLE_CALENDAR_MCP_TOKEN_PATH=/home/node/.openclaw/gcal-token.json

# --- Gmail integration (Phase 3.1, read/draft path) ---
# When set (and FOUNDATION_OFFLINE=0), the assistant's `email.list`,
# `email.read`, and `email.draft` actions run through a Gmail MCP server.
# `email.send` is intentionally gated to Phase 3.2 and will be rejected.
# Leave PA_GMAIL_MCP_CMD empty to keep the deterministic offline stub.
# PA_GMAIL_MCP_CMD=npx
# PA_GMAIL_MCP_ARGS=-y <gmail-mcp-server-package>
# PA_GMAIL_MAX_RESULTS=10
